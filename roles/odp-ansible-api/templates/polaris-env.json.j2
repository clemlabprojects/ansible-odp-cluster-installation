{% set polaris_ssl_enabled = cluster_services.POLARIS is defined and cluster_services.POLARIS.SSL is defined and cluster_services.POLARIS.SSL %}
{% set polaris_oidc_enabled = (oidc_enabled | default(false)) or (cluster_services.OIDC is defined) %}
{% set polaris_scheme = 'https' if polaris_ssl_enabled else 'http' %}
{
  "Clusters": {
    "desired_configs": {
      "type": "polaris-env",
      "tag": "{{ range(00000000, 99999999) | random }}",
      "properties": {
        "polaris_log_dir": "/var/log/polaris",
        "polaris_pid_dir": "/var/run/polaris",
        "polaris_conf_dir": "/etc/polaris/conf",
        "polaris_conf_file": "application.properties",
        "polaris_data_dir": "/var/lib/polaris",
        "polaris_user": "{{ polaris_service_user | default('polaris') }}",
        "polaris_keytab": "{{ polaris_keytab | default('/etc/security/keytabs/polaris.service.keytab') }}",
        "polaris_principal": "{{ polaris_principal_name | default((polaris_service_user | default('polaris')) ~ '/_HOST@' ~ (kerberos_realm | default('EXAMPLE.COM'))) }}",
        "polaris_jaas_file": "/etc/polaris/conf/polaris_jaas.conf",
        "polaris_jaas_context": "PolarisServer",
        "polaris_protocol": "{{ polaris_scheme }}",
        "polaris_ssl_enabled": "{{ 'true' if polaris_ssl_enabled else 'false' }}",
        "polaris_ssl_keystore_password": "{{ polaris_ssl_keystore_password | default(ssl_keystore_password | default('changeit')) }}",
        "polaris_ssl_truststore_password": "{{ polaris_ssl_truststore_password | default(ssl_truststore_password | default('changeit')) }}",
        "polaris_filesystem_type": "{{ 'OZONE' if cluster_services.OZONE is defined else 'HDFS' }}",
        "polaris_opts": "",
        "polaris_mcp_home": "/usr/odp/current/polaris-tools",
        "polaris_mcp_transport": "http",
        "polaris_mcp_protocol": "{{ polaris_scheme }}",
        "polaris_mcp_host": "0.0.0.0",
        "polaris_mcp_port": "8000",
        "polaris_mcp_tls_enabled": "{{ 'true' if polaris_ssl_enabled else 'false' }}",
        "polaris_mcp_tls_cert_file": "{{ security_server_ssl_stores ~ '/server.public.pem' if polaris_ssl_enabled else '' }}",
        "polaris_mcp_tls_key_file": "{{ security_server_ssl_stores ~ '/server.key.pem' if polaris_ssl_enabled else '' }}",
        "polaris_mcp_tls_ca_file": "{{ security_server_ssl_stores ~ '/ca.cert.pem' if polaris_ssl_enabled else '' }}",
        "polaris_mcp_base_url": "{{ polaris_mcp_base_url | default(polaris_scheme ~ '://' ~ (all.get('POLARIS_SERVER', ['localhost'])[0]) ~ ':' ~ ('8443' if polaris_ssl_enabled else '8181') ~ '/') }}",
        "polaris_mcp_start_command": "",
        "polaris_mcp_stop_command": "",
        "polaris_console_home": "/usr/odp/current/polaris-tools",
        "polaris_console_host": "0.0.0.0",
        "polaris_console_protocol": "{{ polaris_scheme }}",
        "polaris_console_port": "8282",
        "polaris_console_tls_enabled": "{{ 'true' if polaris_ssl_enabled else 'false' }}",
        "polaris_console_tls_cert_file": "{{ security_server_ssl_stores ~ '/server.public.pem' if polaris_ssl_enabled else '' }}",
        "polaris_console_tls_key_file": "{{ security_server_ssl_stores ~ '/server.key.pem' if polaris_ssl_enabled else '' }}",
        "polaris_console_start_command": "",
        "polaris_console_stop_command": "",
        "polaris_admin_username": "{{ polaris_admin_username | default('root') }}",
        "polaris_admin_password": "{{ polaris_admin_password | default('s3cr3t') }}",
        "polaris_bootstrap_realms": "POLARIS",
        "polaris_managed_principals": "{{ polaris_managed_principals | default([]) | join(',') }}",
        "polaris_ozone_principal_name": "ozone-engine",
        "polaris_ozone_principal_secret": "{{ polaris_ozone_principal_secret | default('ozone-engine-secret') }}",
        "polaris_ozone_principal_role": "ozone_engineers",
        "polaris_ozone_catalog_name": "ozone",
        "polaris_ozone_catalog_base_location": "s3://ozone/polaris/",
        "polaris_ozone_catalog_allowed_locations": "s3://ozone/",
        "polaris_ozone_s3_endpoint": "{{ polaris_ozone_s3_endpoint | default('http://' ~ (all.get('OZONE_S3_GATEWAY', ['localhost'])[0]) ~ ':9878') }}",
        "polaris_ozone_s3_region": "us-east-1",
        "polaris_ozone_s3_path_style_access": "true",
        "polaris_ozone_catalog_auto_grants": "true",
        "polaris_oidc_use_cluster_config": "{{ 'true' if polaris_oidc_enabled else 'false' }}",
        "polaris_oidc_override_auth_server_url": "{{ polaris_oidc_override_auth_server_url | default('') }}",
        "polaris_oidc_override_client_id": "{{ polaris_oidc_override_client_id | default('') }}",
        "polaris_oidc_override_client_secret": "{{ polaris_oidc_override_client_secret | default('') }}",
        "content": "{% raw %}\n# Java 17+ is required by Polaris. Configure polaris_java_home in Ambari to point to the correct JDK.\nexport JAVA_HOME={{polaris_java_home}}\n\n# Polaris JAAS configuration (used when Kerberos is enabled)\nexport POLARIS_JAAS_FILE={{polaris_jaas_conf}}\n\n# Additional Java opts for Polaris, including Kerberos options when enabled.\n# runtime/distribution/bin/{server,admin} consume POLARIS_JAVA_OPTS.\nexport POLARIS_OPTS=\"{{polaris_opts}} {{polaris_kerberos_opts}}\"\nexport POLARIS_JAVA_OPTS=\"{{polaris_opts}} {{polaris_kerberos_opts}}\"\n\n# Polaris configuration directory\nexport POLARIS_CONF_DIR={{polaris_conf_dir}}\nif [ -z \"${QUARKUS_CONFIG_LOCATIONS:-}\" ]; then\n  export QUARKUS_CONFIG_LOCATIONS=${POLARIS_CONF_DIR}/application.properties,${POLARIS_CONF_DIR}/admin.properties\nfi\nif [ -z \"${SMALLRYE_CONFIG_LOCATIONS:-}\" ]; then\n  export SMALLRYE_CONFIG_LOCATIONS=${QUARKUS_CONFIG_LOCATIONS}\nfi\n\n# Where log files are stored\nexport POLARIS_LOG_DIR={{polaris_log_dir}}\nexport QUARKUS_LOG_FILE_PATH={{polaris_log_dir}}/polaris.log\n\n# PID dir\nexport POLARIS_PID_DIR={{polaris_pid_dir}}\n\n# Data dir\nexport POLARIS_DATA_DIR={{polaris_data_dir}}\n\n# Polaris home\nexport POLARIS_HOME={{polaris_home}}\nexport POLARIS_TOOLS_HOME={{polaris_tools_home}}\n\n# Polaris TLS secret material\nexport POLARIS_SSL_ENABLED={{polaris_ssl_enabled}}\nexport POLARIS_SSL_KEYSTORE_PASSWORD='{{polaris_ssl_keystore_password_escaped}}'\nexport POLARIS_SSL_TRUSTSTORE_PASSWORD='{{polaris_ssl_truststore_password_escaped}}'\n\n# MCP server defaults\nexport POLARIS_BASE_URL={{polaris_mcp_base_url}}\nexport POLARIS_MCP_TRANSPORT={{polaris_mcp_transport}}\nexport POLARIS_MCP_HOST={{polaris_mcp_host}}\nexport POLARIS_MCP_PORT={{polaris_mcp_port}}\nexport POLARIS_MCP_TLS_ENABLED={{polaris_mcp_tls_enabled}}\nexport POLARIS_MCP_TLS_CERT_FILE={{polaris_mcp_tls_cert_file}}\nexport POLARIS_MCP_TLS_KEY_FILE={{polaris_mcp_tls_key_file}}\n{% if polaris_mcp_tls_ca_file %}\nexport POLARIS_MCP_TLS_CA_FILE={{polaris_mcp_tls_ca_file}}\n{% endif %}\n\n# Console defaults\nexport POLARIS_CONSOLE_HOST={{polaris_console_host}}\nexport POLARIS_CONSOLE_PORT={{polaris_console_port}}\nexport POLARIS_CONSOLE_TLS_ENABLED={{polaris_console_tls_enabled}}\nexport POLARIS_CONSOLE_TLS_CERT_FILE={{polaris_console_tls_cert_file}}\nexport POLARIS_CONSOLE_TLS_KEY_FILE={{polaris_console_tls_key_file}}\n\n# Default internal admin credentials (optional)\nexport POLARIS_ADMIN_USER={{polaris_admin_username}}\nexport POLARIS_ADMIN_PASSWORD='{{polaris_admin_password_escaped}}'\n\n# Ozone bootstrap defaults for Polaris\nexport POLARIS_OZONE_CATALOG_NAME={{polaris_ozone_catalog_name}}\nexport POLARIS_OZONE_CATALOG_BASE_LOCATION={{polaris_ozone_catalog_base_location}}\nexport POLARIS_OZONE_CATALOG_ALLOWED_LOCATIONS={{polaris_ozone_catalog_allowed_locations}}\nexport POLARIS_OZONE_S3_ENDPOINT={{polaris_ozone_s3_endpoint}}\nexport POLARIS_OZONE_S3_REGION={{polaris_ozone_s3_region}}\nexport POLARIS_OZONE_S3_PATH_STYLE_ACCESS={{polaris_ozone_s3_path_style_access}}\n    {% endraw %}"
      }
    }
  }
}
