oot.default</name>\n        <value>mem_limit=128m,query_timeout_s=20,max_io_buffers=10</value>\n        <description>read-1:\n            Default Query Memory Limit to the exact amount of memory that Impala should set aside for queries in that pool.\n            read-2:\n            the default query options for all queries that run in this pool,\n            For example, this is where you might set a default memory limit for all queries in the pool, using an argument such as MEM_LIMIT=5G.\n        </description>\n    </property>\n    <property>\n        <name>impala.admission-control.pool-queue-timeout-ms.root.default</name>\n        <value>600000</value>\n        <description> the timeout value for this pool in milliseconds.</description>\n    </property>\n    <property>\n        <name>impala.admission-control.max-query-mem-limit.root.default.regularPool</name>\n        <value>104857600</value><!--100MB-->\n        <description> It gives Impala flexibility to set aside more memory to queries that are expected to be memory-hungry.</description>\n    </property>\n    <property>\n        <name>impala.admission-control.min-query-mem-limit.root.default.regularPool</name>\n        <value>10485760</value><!--10MB-->\n        <description> It gives Impala flexibility to set aside more memory to queries that are expected to be memory-hungry.</description>\n    </property>\n    <property>\n        <name>impala.admission-control.clamp-mem-limit-query-option.root.default.regularPool</name>\n        <value>true</value>\n    </property>\n</configuration>\n            \n        "
